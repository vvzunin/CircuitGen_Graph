{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 26,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "graph-ninja",
      "description": "Ninja backend for fast, parallel builds (default for this project)",
      "hidden": true,
      "generator": "Ninja"
    },
    {
      "name": "cxx-std-17",
      "description": "C++17 with extensions disabled",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_CXX_EXTENSIONS": "OFF",
        "CMAKE_CXX_STANDARD": "17",
        "CMAKE_CXX_STANDARD_REQUIRED": "ON"
      }
    },
    {
      "name": "release-common",
      "description": "Shared Release flags: Ninja, C++17, no dev mode, no coverage",
      "hidden": true,
      "inherits": ["graph-ninja", "cxx-std-17"],
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CircuitGenGraph_DEVELOPER_MODE": "OFF",
        "CircuitGenGraph_BUILD_EXAMPLES": "OFF",
        "ENABLE_COVERAGE": "OFF"
      }
    },
    {
      "name": "cmake-pedantic",
      "description": "Strict CMake diagnostics for local development",
      "hidden": true,
      "warnings": {
        "dev": true,
        "deprecated": true,
        "uninitialized": true,
        "unusedCli": true,
        "systemVars": false
      },
      "errors": {
        "dev": true,
        "deprecated": true
      }
    },
    {
      "name": "dev-mode",
      "description": "Developer mode defaults: examples ON, extra diagnostics, PIC",
      "hidden": true,
      "inherits": "cmake-pedantic",
      "cacheVariables": {
        "CircuitGenGraph_DEVELOPER_MODE": "ON",
        "CircuitGenGraph_BUILD_EXAMPLES": "ON",
        "CMAKE_CXX_FLAGS": "-fPIC"
      }
    },
    {
      "name": "cppcheck",
      "description": "Enable cppcheck static analysis for C++ sources",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_CXX_CPPCHECK": "cppcheck;--inline-suppr"
      }
    },
    {
      "name": "clang-tidy",
      "description": "Enable clang-tidy checks for project code only",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_CXX_CLANG_TIDY": "clang-tidy;--header-filter=^${sourceDir}/src, ^${sourceDir}/include, ^${sourceDir}/examples, ^${sourceDir}/test"
      }
    },
    {
      "name": "ci-std",
      "description": "Alias for cxx-std-17 (CI and legacy preset names)",
      "hidden": true,
      "inherits": ["cxx-std-17"]
    },
    {
      "name": "flags-gcc-clang",
      "description": "These flags are supported by both GCC and Clang",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_CXX_FLAGS": "-U_FORTIFY_SOURCE -D_FORTIFY_SOURCE=3 -D_GLIBCXX_ASSERTIONS=1 -fstack-protector-strong -fcf-protection=full -fstack-clash-protection -Wall -Wextra -Wpedantic -Wconversion -Wsign-conversion -Wcast-qual -Wformat=2 -Wundef -Wshadow -Wcast-align -Wunused -Wnull-dereference -Wdouble-promotion -Wimplicit-fallthrough -Wextra-semi -Woverloaded-virtual -Wnon-virtual-dtor -Wold-style-cast",
        "CMAKE_EXE_LINKER_FLAGS": "-Wl,--allow-shlib-undefined,--as-needed,-z,noexecstack,-z,relro,-z,now,-z,nodlopen",
        "CMAKE_SHARED_LINKER_FLAGS": "-Wl,--allow-shlib-undefined,--as-needed,-z,noexecstack,-z,relro,-z,now,-z,nodlopen"
      }
    },
    {
      "name": "flags-appleclang",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_CXX_FLAGS": "-fstack-protector-strong -Wall -Wextra -Wpedantic -Wconversion -Wsign-conversion -Wcast-qual -Wformat=2 -Wundef -Wshadow -Wcast-align -Wunused -Wnull-dereference -Wdouble-promotion -Wimplicit-fallthrough -Wextra-semi -Woverloaded-virtual -Wnon-virtual-dtor -Wold-style-cast"
      }
    },
    {
      "name": "flags-msvc",
      "description": "Note that all the flags after /W4 are required for MSVC to conform to the language standard",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_CXX_FLAGS": "/sdl /guard:cf /utf-8 /diagnostics:caret /w14165 /w44242 /w44254 /w44263 /w34265 /w34287 /w44296 /w44365 /w44388 /w44464 /w14545 /w14546 /w14547 /w14549 /w14555 /w34619 /w34640 /w24826 /w14905 /w14906 /w14928 /w45038 /W4 /permissive- /volatile:iso /Zc:inline /Zc:preprocessor /Zc:enumTypes /Zc:lambda /Zc:__cplusplus /Zc:externConstexpr /Zc:throwingNew /EHsc",
        "CMAKE_EXE_LINKER_FLAGS": "/machine:x64 /guard:cf"
      }
    },
    {
      "name": "ci-linux",
      "description": "Legacy Linux CI alias (kept for compatibility)",
      "hidden": true,
      "inherits": ["ci-base"],
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      }
    },
    {
      "name": "ci-base",
      "description": "Cross-platform CI baseline: Ninja + C++17 + Release",
      "hidden": true,
      "inherits": ["graph-ninja", "ci-std"],
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "coverage-linux",
      "description": "Linux coverage configuration (gcov/lcov toolchain)",
      "binaryDir": "${sourceDir}/build/coverage",
      "inherits": "ci-linux",
      "hidden": true,
      "cacheVariables": {
        "ENABLE_COVERAGE": "ON",
        "CMAKE_BUILD_TYPE": "Coverage",
        "CMAKE_CXX_FLAGS_COVERAGE": "-Og -g --coverage -fkeep-inline-functions",
        "CMAKE_EXE_LINKER_FLAGS_COVERAGE": "--coverage",
        "CMAKE_SHARED_LINKER_FLAGS_COVERAGE": "--coverage"
      }
    },
    {
      "name": "ci-coverage",
      "displayName": "CI Coverage (Linux)",
      "description": "Run tests with coverage collection and summary output",
      "inherits": ["coverage-linux", "dev-mode"],
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      },
      "cacheVariables": {
        "COVERAGE_ENABLE_HTML": "OFF"
      }
    },
    {
      "name": "ci-sanitize",
      "displayName": "CI Sanitize",
      "description": "ASan/UBSan build for fast runtime issue detection",
      "binaryDir": "${sourceDir}/build/sanitize",
      "inherits": ["ci-base", "dev-mode"],
      "condition": {
        "type": "notEquals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Sanitize",
        "CMAKE_CXX_FLAGS_SANITIZE": "-U_FORTIFY_SOURCE -O2 -g -fsanitize=address,undefined -fno-omit-frame-pointer -fno-common"
      }
    },
    {
      "name": "ci-build",
      "description": "Shared CI binary directory root",
      "binaryDir": "${sourceDir}/build",
      "hidden": true
    },
    {
      "name": "ci-ubuntu",
      "displayName": "CI Ubuntu",
      "description": "Main Linux CI profile with lint tools enabled",
      "inherits": ["ci-build", "ci-base", "clang-tidy", "cppcheck", "dev-mode"],
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      }
    },
    {
      "name": "ci-static-analysis",
      "displayName": "CI static analysis",
      "description": "clang-tidy during compile; cppcheck is run from scripts/ci/static-analysis.sh (project mode, not CMAKE_CXX_CPPCHECK)",
      "inherits": ["ci-build", "ci-base", "clang-tidy", "dev-mode"],
      "binaryDir": "${sourceDir}/build/static-analysis",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      }
    },
    {
      "name": "ci-self",
      "displayName": "CI Self",
      "description": "Cross-platform self-hosted CI profile",
      "inherits": ["ci-build", "ci-base", "clang-tidy", "cppcheck", "dev-mode"]
    },
    {
      "name": "release",
      "displayName": "Release",
      "description": "Optimized release build for packaging and deployment (no tests)",
      "inherits": ["release-common"],
      "binaryDir": "${sourceDir}/build/release",
      "cacheVariables": {
        "BUILD_TESTING": "OFF"
      }
    },
    {
      "name": "release-ci",
      "displayName": "Release (CI)",
      "description": "Release configuration with tests enabled (GitLab CI, local parity)",
      "inherits": ["release-common"],
      "binaryDir": "${sourceDir}/build/release-ci",
      "cacheVariables": {
        "BUILD_TESTING": "ON"
      }
    },
    {
      "name": "ci-examples-dev",
      "displayName": "Examples (Debug)",
      "description": "Debug build with developer mode and examples (CI / docs parity with local dev preset)",
      "inherits": ["dev-mode", "ci-base"],
      "binaryDir": "${sourceDir}/build/ci-examples-dev",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "release-examples",
      "displayName": "Release with examples",
      "description": "Optimized release with example programs built and runnable (no unit tests)",
      "inherits": ["release"],
      "binaryDir": "${sourceDir}/build/release-examples",
      "cacheVariables": {
        "CircuitGenGraph_BUILD_EXAMPLES": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "release",
      "displayName": "Build Release",
      "description": "Compile production configuration without tests",
      "configurePreset": "release",
      "jobs": 0
    },
    {
      "name": "release-ci",
      "displayName": "Build Release (CI)",
      "description": "Compile release configuration used by CI tests",
      "configurePreset": "release-ci",
      "jobs": 0
    },
    {
      "name": "ci-static-analysis",
      "displayName": "Build static analysis",
      "description": "clang-tidy and cppcheck during compilation",
      "configurePreset": "ci-static-analysis",
      "jobs": 0
    },
    {
      "name": "ci-examples-dev",
      "displayName": "Build examples (Debug)",
      "configurePreset": "ci-examples-dev",
      "jobs": 0
    },
    {
      "name": "release-examples",
      "displayName": "Build release with examples",
      "configurePreset": "release-examples",
      "jobs": 0
    }
  ],
  "testPresets": [
    {
      "name": "release-ci",
      "displayName": "Test Release (CI)",
      "description": "Run ctest for release-ci and fail if no tests are found",
      "configurePreset": "release-ci",
      "output": {
        "outputOnFailure": true
      },
      "execution": {
        "noTestsAction": "error"
      }
    }
  ]
}
