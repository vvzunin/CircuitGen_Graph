{
  "schemaVersion": 1,
  "dockerDefaults": {
    "registryHost": "vvzunin.me:5201",
    "group": "circuitgen",
    "osList": ["ubuntu-22.04", "ubuntu-24.04", "fedora-43"],
    "devTag": "main",
    "harborWebBase": "https://vvzunin.me/harbor/projects/circuitgen/repositories"
  },
  "modules": [
    {
      "id": "graph",
      "name": { "ru": "Graph", "en": "Graph" },
      "description": {
        "ru": "Графовое представление цифровых схем",
        "en": "Graph representation of digital circuits"
      },
      "repo": "https://hub.mos.ru/circuitgen/CircuitGen_Graph",
      "docker": { "imageRepo": "graph", "releaseTag": "v1.6.0" }
    },
    {
      "id": "generator",
      "name": { "ru": "Generator", "en": "Generator" },
      "description": {
        "ru": "Генератор цифровых схем",
        "en": "Digital circuit generator"
      },
      "repo": "https://hub.mos.ru/circuitgen/CircuitGen_Generator",
      "docker": { "imageRepo": "generator", "releaseTag": "v1.3.1" }
    },
    {
      "id": "parameters",
      "name": { "ru": "Parameters", "en": "Parameters" },
      "description": {
        "ru": "Расчёт параметров цифровых схем",
        "en": "Digital circuit parameter estimation"
      },
      "repo": "https://hub.mos.ru/circuitgen/CircuitGen_Parameters",
      "docker": { "imageRepo": "parameters", "releaseTag": "v0.5.0" }
    },
    {
      "id": "ai",
      "name": { "ru": "AI", "en": "AI" },
      "description": {
        "ru": "Машинное обучение для оценки параметров схем",
        "en": "Machine learning for circuit parameter estimation"
      },
      "repo": "https://hub.mos.ru/circuitgen/CircuitGen_AI",
      "planned": true
    },
    {
      "id": "lorina",
      "name": { "ru": "Lorina", "en": "Lorina" },
      "description": {
        "ru": "Парсер Verilog (интеграция Lorina)",
        "en": "Verilog parser (Lorina integration)"
      },
      "repo": "https://hub.mos.ru/circuitgen/lorina",
      "planned": true
    },
    {
      "id": "testing",
      "name": { "ru": "Testing", "en": "Testing" },
      "description": {
        "ru": "Инфраструктура тестирования CircuitGen",
        "en": "CircuitGen testing infrastructure"
      },
      "repo": "https://hub.mos.ru/circuitgen/CircuitGen_Testing",
      "planned": true
    },
    {
      "id": "circuitgen",
      "name": { "ru": "CircuitGen", "en": "CircuitGen" },
      "description": {
        "ru": "Единая система генерации и хранения датасета",
        "en": "Unified dataset generation and storage system"
      },
      "repo": "https://hub.mos.ru/circuitgen/CircuitGen",
      "planned": true
    }
  ]
}
