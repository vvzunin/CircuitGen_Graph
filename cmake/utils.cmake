include("${CMAKE_CURRENT_LIST_DIR}/colors.cmake")
define_colors()
set(default_output_max_len 80)

function(print_as_title arg1) # line_max_len place_holder alignment APPEND color)
  set(empty_string "")
  if (ARGC GREATER_EQUAL 2)
    set(line_max_len ${ARGV1})
  else()
    set(line_max_len ${default_output_max_len})
  endif()

  if (ARGC GREATER_EQUAL 3)
    set(place_holder ${ARGV2})
  else()
    set(place_holder "-")
  endif()

  if (ARGC GREATER_EQUAL 4)
    set(alignment ${ARGV3})
  else()
    set(alignment "c")
  endif()

  if (ARGC GREATER_EQUAL 5)
    if(${ARGV4})
      set(APPEND echo_append)
    else()
      set(APPEND echo)
    endif()
  else()
    set(APPEND echo)
  endif()

  if (ARGC GREATER_EQUAL 6)
    if(${ARGV5})
      set(color ${ARGV5})
    else()
      set(color empty_string)
    endif()
  else()
    set(color empty_string)
  endif()

  string(LENGTH ${arg1}, len_arg1)
  math(EXPR extra_chars "${line_max_len} - ${len_arg1} + 1")

  if (alignment STREQUAL "c")
    if(len_arg1 EQUAL 1)
      string(REPEAT ${place_holder} ${line_max_len} sep)
      #message(NOTICE "${sep}")
      execute_process(COMMAND ${CMAKE_COMMAND} -E ${APPEND} "${${color}}${sep}${ColorReset}")
    elseif(${len_arg1} GREATER ${line_max_len})
      #message(NOTICE "${arg1}")
      execute_process(COMMAND ${CMAKE_COMMAND} -E ${APPEND} "${${color}}${arg1}${ColorReset}")
    elseif(${extra_chars} LESS_EQUAL 2)
      math(EXPR prev_s_len "${extra_chars} % 2")
      string(REPEAT " " ${prev_s_len} prev_s)
      math(EXPR after_s_len "${extra_chars} / 2")
      string(REPEAT " " ${after_s_len} after_s)
      #message(NOTICE "${prev_s}${arg1}${after_s}")
      execute_process(COMMAND ${CMAKE_COMMAND} -E ${APPEND} "${${color}}${prev_s}${arg1}${after_s}${ColorReset}")
    else()
      math(EXPR extra_chars "${extra_chars} - 2")
      math(EXPR prev_s_len "${extra_chars} / 2")
      string(REPEAT ${place_holder} ${prev_s_len} prev_s)
      math(EXPR after_s_len "${extra_chars} / 2 + ${extra_chars} % 2")
      string(REPEAT ${place_holder} ${after_s_len} after_s)
      #message(NOTICE "${prev_s} ${arg1} ${after_s}")
      execute_process(COMMAND ${CMAKE_COMMAND} -E ${APPEND} "${${color}}${prev_s} ${arg1} ${after_s}${ColorReset}")
    endif()
  elseif(alignment STREQUAL "l")
    if(len_arg1 EQUAL 1)
      string(REPEAT ${place_holder} ${line_max_len} sep)
      #message(NOTICE "${sep}")
      execute_process(COMMAND ${CMAKE_COMMAND} -E ${APPEND} "${${color}}${sep}${ColorReset}")
    elseif(${len_arg1} GREATER ${line_max_len})
      #message(NOTICE "${arg1}")
      execute_process(COMMAND ${CMAKE_COMMAND} -E ${APPEND} "${${color}}${arg1}${ColorReset}")
    elseif(${extra_chars} LESS_EQUAL 1)
      string(REPEAT " " ${extra_chars} after_s)
      #message(NOTICE "${arg1}${after_s}")
      execute_process(COMMAND ${CMAKE_COMMAND} -E ${APPEND} "${${color}}${arg1}${after_s}${ColorReset}")
    else()
      math(EXPR extra_chars "${extra_chars} - 1")
      string(REPEAT ${place_holder} ${extra_chars} after_s)
      #message(NOTICE "${arg1} ${after_s}" APPEND)
      execute_process(COMMAND ${CMAKE_COMMAND} -E ${APPEND} "${${color}}${arg1} ${after_s}${ColorReset}")
    endif()
  elseif(alignment STREQUAL "r")
    if(len_arg1 EQUAL 1)
      string(REPEAT ${place_holder} ${line_max_len} sep)
      #message(NOTICE "${sep}")
      execute_process(COMMAND ${CMAKE_COMMAND} -E ${APPEND} "${${color}}${sep}${ColorReset}")
    elseif(${len_arg1} GREATER ${line_max_len})
      #message(NOTICE "${arg1}")
      execute_process(COMMAND ${CMAKE_COMMAND} -E ${APPEND} "${${color}}${arg1}${ColorReset}")
    elseif(${extra_chars} LESS_EQUAL 1)
      string(REPEAT " " ${extra_chars} befor_s)
      #message(NOTICE "${befor_s}${arg1}")
      execute_process(COMMAND ${CMAKE_COMMAND} -E ${APPEND} "${${color}}${befor_s}${arg1}${ColorReset}")
    else()
      math(EXPR extra_chars "${extra_chars} - 1")
      string(REPEAT ${place_holder} ${extra_chars} befor_s)
      #message(NOTICE "${befor_s} ${arg1}")
      execute_process(COMMAND ${CMAKE_COMMAND} -E ${APPEND} "${${color}}${befor_s} ${arg1}${ColorReset}")
    endif()
  endif()
endfunction()

function(print_message_two_parts part1 part2 part1_line_max_len color)
  print_as_title(${part1} ${part1_line_max_len} " " "l" ON ${color})
  print_as_title(${part2} 0 " " "l" OFF ${color})
endfunction()

function(print_cmake_info color)

  set(first_part_len 36)
  print_as_title("" ${default_output_max_len} " " "c" OFF ${color})
  print_as_title("" ${default_output_max_len} "-" "c" OFF ${color})
  print_as_title("Main info about CMake" ${default_output_max_len} "-" "c" OFF ${color})
  print_as_title("" ${default_output_max_len} "-" "c" OFF ${color})

  print_message_two_parts("- CMake version"                       ": ${CMAKE_VERSION}"                  ${first_part_len} ${color})
  print_message_two_parts("- CMake graph"                     ": ${CMAKE_GENERATOR}"              ${first_part_len} ${color})
  print_message_two_parts("- Target CMake system name"            ": ${CMAKE_SYSTEM_NAME}"            ${first_part_len} ${color})
  print_message_two_parts("- Target CMake system processor"       ": ${CMAKE_SYSTEM_PROCESSOR}"       ${first_part_len} ${color})
  print_message_two_parts("- Target CMake system version"         ": ${CMAKE_SYSTEM_VERSION}"         ${first_part_len} ${color})
  print_message_two_parts("- Target CMake host system name"       ": ${CMAKE_HOST_SYSTEM_NAME}"       ${first_part_len} ${color})
  print_message_two_parts("- Target CMake host system processor"  ": ${CMAKE_HOST_SYSTEM_PROCESSOR}"  ${first_part_len} ${color})
  print_message_two_parts("- Target CMake host system version"    ": ${CMAKE_HOST_SYSTEM_VERSION}"    ${first_part_len} ${color})
  print_as_title("" ${default_output_max_len} "-" "c" OFF ${color})
endfunction()

function(print_build_info color)

  set(first_part_len 37)
  print_as_title("" ${default_output_max_len} " " "c" OFF ${color})
  print_as_title("" ${default_output_max_len} "-" "c" OFF ${color})
  print_as_title("Main info about build" ${default_output_max_len} "-" "c" OFF ${color})
  print_as_title("" ${default_output_max_len} "-" "c" OFF ${color})

  print_message_two_parts("- PROJECT_SOURCE_DIR"        ": ${PROJECT_SOURCE_DIR}"       ${first_part_len} ${color})
  print_message_two_parts("- PROJECT_BINARY_DIR"        ": ${PROJECT_BINARY_DIR}"       ${first_part_len} ${color})
  print_message_two_parts("- CMAKE_INSTALL_INCLUDEDIR"  ": ${CMAKE_INSTALL_INCLUDEDIR}" ${first_part_len} ${color})

  if(NOT(CMAKE_SYSTEM_NAME IN_LIST PROJECT_SUPPORTED_SYSTEMS))
    print_message_two_parts("- Target CMake system are not supported" ": ${CMAKE_SYSTEM_NAME}"          ${first_part_len} Red)
    print_message_two_parts("- Supported systems"                     ": ${PROJECT_SUPPORTED_SYSTEMS}"  ${first_part_len} Red)
  endif()
  print_message_two_parts("- CMake interprocedural optimization"  ": ${ipo_supported}" ${first_part_len} ${color})
  print_as_title("" ${default_output_max_len} "-" "c" OFF ${color})
endfunction()

