# Avoid CMake dev-mode errors when printing cache/options that may be unset
# (e.g. project pulled in as a dependency before top-level initializes these).
function(_utils_print_kv_optional label_out var_name first_part_len color)
  if(DEFINED "${var_name}")
    print_message_two_parts("${label_out}" ": ${${var_name}}" ${first_part_len} ${color})
  else()
    print_message_two_parts("${label_out}" ": <unset>" ${first_part_len} ${color})
  endif()
endfunction()

